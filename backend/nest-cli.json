{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "src/main",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger"],
    "assets": [
      { "include": "modules/reports/pdf/templates/**/*", "watchAssets": true },
      { "include": "modules/reports/pdf/fonts/**/*", "watchAssets": true }
    ]
  }
}
