{
  "name": "softtime",
  "private": true,
  "workspaces": [
    "backend",
    "mobile",
    "web",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-reanimated-gradle.js",
    "backend": "npm run start:dev --workspace=backend",
    "mobile": "npm start --workspace=mobile",
    "web": "npm run dev --workspace=web",
    "android": "npm run android --workspace=mobile",
    "ios": "npm run ios --workspace=mobile"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-worklets": "~0.8.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.0"
  },
  "overrides": {
    "@types/react": "^19.2.0"
  }
}