{
  "name": "softtime",
  "private": true,
  "workspaces": [
    "backend",
    "mobile",
    "web",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-reanimated-gradle.js && node scripts/patch-expo-metro-events.js",
    "backend": "npm run start:dev --workspace=backend",
    "mobile": "npm start --workspace=mobile",
    "web": "npm run dev --workspace=web",
    "android": "npm run android --workspace=mobile",
    "ios": "npm run ios --workspace=mobile"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-worklets": "~0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10"
  },
  "overrides": {
    "@types/react": "~19.1.10",
    "metro": "0.84.4",
    "metro-config": "0.84.4",
    "metro-cache": "0.84.4",
    "metro-core": "0.84.4",
    "metro-runtime": "0.84.4",
    "metro-babel-transformer": "0.84.4",
    "@react-native/metro-config": "0.86.0",
    "@react-native/babel-preset": "0.86.0",
    "hermes-parser": "0.36.0",
    "hermes-estree": "0.36.0"
  }
}