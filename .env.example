# PostgreSQL
POSTGRES_USER=softtime
POSTGRES_PASSWORD=softtime
POSTGRES_DB=softtime
DATABASE_URL=postgresql://softtime:softtime@postgres:5432/softtime
# For local dev (outside Docker) use port 5433 if local PostgreSQL occupies 5432:
# DATABASE_URL=postgresql://softtime:softtime@localhost:5433/softtime

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change_me_min_32_chars_long_secret
JWT_REFRESH_SECRET=change_me_another_min_32_chars_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Firebase FCM
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Business rules
GRACE_PERIOD_DAYS=7
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_BLOCK_MINUTES=15
