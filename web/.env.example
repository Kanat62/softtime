# Backend API base URL (including /api/v1 prefix).
#
# Development: leave unset — the Vite dev server proxies /api/* to http://localhost:3000
#   automatically (see vite.config.ts server.proxy). No env var needed.
#
# Production / staging: set this to the real backend origin, e.g.:
#   VITE_API_URL=https://api.softtime.app/api/v1
VITE_API_URL=
