# SoftTime Mobile — environment variables
# Copy to .env and fill in the values.

# Backend base URL (WITHOUT /api/v1 — the client appends it automatically).
#
# Dev on an emulator:
#   Android emulator → http://10.0.2.2:3000
#   iOS Simulator    → http://localhost:3000
#
# Dev on a PHYSICAL device (both iOS and Android):
#   Use your machine's LAN IP:  http://192.168.X.X:3000
#   Find it with: ipconfig (Windows) / ifconfig (macOS/Linux)
#   Or use a tunnel: npx expo start --tunnel (requires @expo/ngrok)
#
# Production:
#   EXPO_PUBLIC_API_URL=https://api.softtime.app
EXPO_PUBLIC_API_URL=http://localhost:3000
